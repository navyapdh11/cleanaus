{
  "version": 2,
  "name": "cleanaus-api",
  "builds": [
    {
      "src": "services/api/src/main.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "services/api/src/main.ts"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "DB_ENABLED": "false",
    "OTEL_ENABLED": "false"
  },
  "regions": ["syd1"],
  "public": false
}
