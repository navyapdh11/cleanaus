# CleanAUS Enterprise Platform - Environment Configuration
# Copy this file to .env and update with your values

# ============================================
# Application
# ============================================
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:3000

# ============================================
# Database (PostgreSQL)
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=cleanaus
DB_PASSWORD=your_secure_password_here
DB_NAME=cleanaus_prod
DB_LOGGING=false
DB_SSL=false

# ============================================
# Redis
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# ============================================
# JWT Authentication
# ============================================
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here_change_in_production
JWT_REFRESH_EXPIRES_IN=30d

# ============================================
# Stripe (Australian payments)
# ============================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_CURRENCY=aud

# ============================================
# OpenTelemetry
# ============================================
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=cleanaus-api

# ============================================
# Email (Australian business)
# ============================================
SMTP_HOST=smtp.yourprovider.com.au
SMTP_PORT=587
SMTP_USERNAME=noreply@cleanaus.com.au
SMTP_PASSWORD=your_smtp_password
SMTP_FROM_NAME=CleanAUS

# ============================================
# AI/OASIS Configuration
# ============================================
OASIS_MCTS_ITERATIONS=100
OASIS_GOT_ITERATIONS=3
OASIS_AGENT_TIMEOUT=30000
